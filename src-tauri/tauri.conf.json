{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Gorgonetics",
  "version": "0.5.2",
  "identifier": "com.gorgonetics.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Gorgonetics Labs",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost blob: data:; connect-src ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/images/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDMjA3OERCN0Q3RTM5RUUKUldUdU9YNTkyM2dnclA0VW0xNHF0TEkwVHVmeGR2VEMxekZaMVR2WW1RNDFFRm5uMk9kdzRTOWwK",
      "endpoints": [
        "https://github.com/gorgonetics/Gorgonetics/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/assets/**/*.json",
      "resources/data/*.txt"
    ]
  }
}
