# Gorgonetics — Environment Configuration
# Copy this file to .env and fill in production values.

# ---------------------------------------------------------------------------
# Runtime mode — set to "production" to enforce a strong JWT secret
# ---------------------------------------------------------------------------
GORGONETICS_ENV=development

# ---------------------------------------------------------------------------
# JWT Authentication
# REQUIRED in production — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
GORGONETICS_JWT_SECRET_KEY=your-secret-key-change-this-in-production
GORGONETICS_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
GORGONETICS_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# DuckLake Database (SQLite catalog + Parquet data files)
# For Docker deployments, these should point inside the mounted volume.
# ---------------------------------------------------------------------------
GORGONETICS_CATALOG_PATH=metadata.sqlite
GORGONETICS_DATA_PATH=data
GORGONETICS_DUCKLAKE_NAME=gorgonetics_lake

# ---------------------------------------------------------------------------
# Multi-user settings
# ---------------------------------------------------------------------------
GORGONETICS_CONCURRENT_ACCESS=true
GORGONETICS_SESSION_TIMEOUT=30

# ---------------------------------------------------------------------------
# Web server
# ---------------------------------------------------------------------------
# CORS: comma-separated list of allowed origins. Use "*" for dev only.
GORGONETICS_CORS_ORIGINS=*
# Auto-populate gene data from assets/ when the database is empty on startup.
GORGONETICS_LOAD_SAMPLE_DATA=false
# Maximum genome file upload size in bytes (default 5 MB).
GORGONETICS_MAX_UPLOAD_BYTES=5242880
# Port override (used by Railway, Fly.io, Render — leave unset for default 8000).
# PORT=8000
