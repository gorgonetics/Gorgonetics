# Gorgonetics Database Configuration
# Uses DuckLake with SQLite catalog for data versioning and concurrent access

# SQLite catalog database path (stores metadata and transaction log)
GORGONETICS_CATALOG_PATH=metadata.sqlite

# Directory for Parquet data files
GORGONETICS_DATA_PATH=data

# DuckLake database name
GORGONETICS_DUCKLAKE_NAME=gorgonetics_lake

# Enable concurrent access for multiple users
GORGONETICS_CONCURRENT_ACCESS=true

# Session timeout in minutes
GORGONETICS_SESSION_TIMEOUT=30
