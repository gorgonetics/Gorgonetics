{
  "name": "gorgonetics",
  "version": "0.6.3",
  "description": "Gorgon genetics breeding tool for Project Gorgon",
  "type": "module",
  "private": true,
  "scripts": {
    "gen:gene-colors-css": "node scripts/gen-gene-colors-css.mjs",
    "sync:bundled-assets": "node scripts/sync-bundled-assets.mjs",
    "dev": "pnpm gen:gene-colors-css && pnpm sync:bundled-assets && vite dev",
    "build": "pnpm gen:gene-colors-css && pnpm sync:bundled-assets && vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "PATH=\"/opt/homebrew/opt/llvm/bin:$PATH\" tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:ci": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:firestore": "firebase emulators:exec --only firestore --project demo-gorgonetics 'vitest run --config vitest.integration.config.js'",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "screenshots": "node scripts/capture-quickstart-screenshots.mjs",
    "release": "bash scripts/release.sh",
    "clean": "rm -rf node_modules/.cache/ .vite/ test-results/ playwright-report/",
    "setup": "pnpm install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/ui": "^4.1.1",
    "firebase-tools": "^15.18.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.55.5",
    "vite": "^8.0.12",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@lucide/svelte": "^1.14.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "firebase": "^12.13.0",
    "jszip": "^3.10.1"
  },
  "keywords": [
    "project-gorgon",
    "genetics",
    "breeding",
    "game-tool"
  ],
  "author": "Javier Lopez Pena",
  "license": "MIT",
  "packageManager": "pnpm@11.0.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
