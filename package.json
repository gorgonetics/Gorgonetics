{
  "name": "gorgonetics",
  "version": "0.1.0",
  "description": "Gorgon genetics breeding tool for Project Gorgon",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "generate:templates": "node scripts/generate-gene-templates.js",
    "lint": "eslint src/**/*.{js,svelte} *.js",
    "lint:fix": "eslint src/**/*.{js,svelte} *.js --fix",
    "lint:strict": "eslint src/**/*.{js,svelte} *.js --max-warnings=0",
    "lint:ci": "eslint src/**/*.{js,svelte} *.js --max-warnings=0",
    "test": "vitest",
    "test:client": "node scripts/run_client_tests.js run",
    "test:client:watch": "node scripts/run_client_tests.js watch",
    "test:client:ui": "node scripts/run_client_tests.js ui",
    "test:client:coverage": "node scripts/run_client_tests.js coverage",
    "test:integration": "./test.sh quick",
    "test:all": "./test.sh all",
    "clean:client": "rm -rf node_modules/.cache/ .vite/",
    "clean:test": "node scripts/clean_test_artifacts.js",
    "test:client:clean": "pnpm test:client && pnpm clean:test",
    "setup": "pnpm install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@vitest/ui": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "svelte": "^5.55.0",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@flowbite-svelte-plugins/datatable": "^0.4.1",
    "@lucide/svelte": "^1.7.0",
    "@tailwindcss/vite": "^4.2.2",
    "flowbite": "^4.0.1",
    "flowbite-svelte": "^1.31.0",
    "simple-datatables": "^10.2.0",
    "tailwindcss": "^4.2.2"
  },
  "keywords": [
    "project-gorgon",
    "genetics",
    "breeding",
    "game-tool"
  ],
  "author": "Javier Lopez Pena",
  "license": "MIT"
}
