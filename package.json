{
  "name": "gorgonetics",
  "version": "0.1.0-alpha.1",
  "description": "Gorgon genetics breeding tool for Project Gorgon",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "generate:templates": "node scripts/generate-gene-templates.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:ci": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "clean": "rm -rf node_modules/.cache/ .vite/ test-results/ playwright-report/",
    "setup": "pnpm install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/ui": "^4.1.1",
    "jsdom": "^29.0.1",
    "svelte": "^5.55.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@lucide/svelte": "^1.7.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "tailwindcss": "^4.2.2"
  },
  "keywords": [
    "project-gorgon",
    "genetics",
    "breeding",
    "game-tool"
  ],
  "author": "Javier Lopez Pena",
  "license": "MIT"
}
