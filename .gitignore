# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# IDE
.idea/
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Node.js
node_modules/
npm-debug.log*
.npm
.eslintcache

# SvelteKit / Vite
.svelte-kit/
.vite/
build/
dist/

# Tauri
src-tauri/target/
src-tauri/gen/

# Bundled mirrors of canonical assets/ and data/ (regenerated by
# `pnpm sync:bundled-assets`, which runs as part of `pnpm dev`/`pnpm build`)
src-tauri/resources/assets/
src-tauri/resources/data/

# SQLite database (generated at runtime)
*.db
*.db-journal

# Environment
.env

# Firebase Admin SDK service-account keys (used by
# scripts/monitor-spark-usage.mjs). Keys must live OUTSIDE the
# repo (default: ~/.config/gorgonetics/) but the patterns below
# defend against accidental drops into the repo root.
*service-account*.json
firebase-admin-key*.json

# Playwright
playwright-report/
test-results/
.playwright-mcp/

# Static copies for browser-mode testing
src/static/assets/
src/static/data/
tests/playwright/screenshots/

# Python remnants (safe to delete from disk)
__pycache__/
*.pyc
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
metadata.sqlite
*.egg-info/

# AI plugin artifacts
docs/superpowers/
.superpowers/
.omc/
.claude/

# Misc
*.backup
temp/
tmp/
*.log
